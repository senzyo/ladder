{
  "log": {
    "access": "none",
    "error": "none",
    "loglevel": "warning",
    "dnsLog": true,
    "maskAddress": ""
  },
  "dns": {
    "hosts": {
      "domain:googleapis.cn": ["googleapis.com"],
      "dns.alidns.com": ["223.5.5.5", "223.6.6.6"]
    },
    "servers": [
      "8.8.8.8",
      {
        "address": "https+local://dns.alidns.com/dns-query",
        "domains": [
          "geosite:private",
          "geosite:category-games@cn",
          "geosite:kaspersky",
          "cfcn-a-proctusa.chinabaidu.pp.ua",
          "cf-cname.xingpingcn.top",
          "singgcdn.singgnetworkcdn.com",
          "www.shopify.com",
          "store.ubi.com",
          "staticdelivery.nexusmods.com"
        ],
        "skipFallback": true
      },
      {
        "address": "8.8.8.8",
        "domains": ["geosite:geolocation-!cn"],
        "skipFallback": true
      },
      {
        "address": "https+local://dns.alidns.com/dns-query",
        "domains": ["geosite:cn"],
        "skipFallback": true
      }
    ],
    "tag": "dns-module",
    "queryStrategy": "UseIPv4",
    "useSystemHosts": false
  },
  "inbounds": [
    {
      "tag": "in-tun",
      "protocol": "tun",
      "settings": {
        "name": "xray0",
        "mtu": 1500,
        "gateway": ["172.18.0.1/24", "fdfe:dcba:9876::1/64"],
        "dns": [
          "1.1.1.1",
          "1.0.0.1",
          "2606:4700:4700::1111",
          "2606:4700:4700::1001"
        ],
        "autoSystemRoutingTable": ["0.0.0.0/0", "::/0"],
        "autoOutboundsInterface": "auto"
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls"],
        "metadataOnly": false,
        "routeOnly": true
      }
    }
  ],
  "outbounds": [
    {
      "tag": "out-proxy",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "<VPS_IPv4>",
            "port": 443,
            "users": [
              {
                "id": "<XHTTP_UUID>",
                "flow": "",
                "encryption": "none"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "reality",
        "realitySettings": {
          "serverName": "<Reality_Site>",
          "fingerprint": "chrome",
          "password": "<Reality_publicKey>",
          "shortId": "<Reality_shortId>",
          "spiderX": "/",
          "show": false
        },
        "xhttpSettings": {
          "mode": "auto",
          "host": "",
          "path": "/<XHTTP_PATH>",
          "extra": {
            "downloadSettings": {
              "address": "<Cloudflare_1>",
              "port": 443,
              "network": "xhttp",
              "security": "tls",
              "tlsSettings": {
                "serverName": "<XHTTP_CDN_Site>",
                "fingerprint": "chrome",
                "alpn": ["h2"],
                "show": false
              },
              "xhttpSettings": {
                "mode": "auto",
                "host": "<XHTTP_CDN_Site>",
                "path": "/<XHTTP_PATH>"
              }
            }
          }
        }
      }
    },
    {
      "tag": "out-direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIPv4"
      }
    },
    {
      "tag": "out-block",
      "protocol": "blackhole"
    },
    {
      "tag": "out-dns",
      "protocol": "dns"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "inboundTag": ["in-tun"],
        "port": "53",
        "outboundTag": "out-dns"
      },
      {
        "inboundTag": ["dns-module"],
        "outboundTag": "out-proxy"
      },
      {
        "domain": ["geosite:private"],
        "outboundTag": "out-direct"
      },
      {
        "ip": ["ext:geoip-only-cn-private.dat:private"],
        "outboundTag": "out-direct"
      },
      {
        "network": "udp",
        "port": "443",
        "outboundTag": "out-block"
      },
      {
        "port": "853",
        "protocol": ["tls"],
        "outboundTag": "out-block"
      },
      {
        "protocol": ["bittorrent"],
        "outboundTag": "out-direct"
      },
      {
        "domain": [
          "geosite:category-games@cn",
          "geosite:kaspersky",
          "cfcn-a-proctusa.chinabaidu.pp.ua",
          "cf-cname.xingpingcn.top",
          "singgcdn.singgnetworkcdn.com",
          "www.shopify.com",
          "store.ubi.com",
          "staticdelivery.nexusmods.com"
        ],
        "outboundTag": "out-direct"
      },
      {
        "domain": ["geosite:geolocation-!cn"],
        "outboundTag": "out-proxy"
      },
      {
        "domain": ["geosite:cn"],
        "outboundTag": "out-direct"
      },
      {
        "ip": ["ext:geoip-only-cn-private.dat:cn"],
        "outboundTag": "out-direct"
      }
    ]
  }
}
